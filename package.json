{
  "name": "picc-push",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "dev:local": "next dev --hostname 127.0.0.1 --port 3010",
    "build": "next build",
    "test": "vitest run",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint app components lib prisma --ext .ts,.tsx",
    "typecheck": "rm -f tsconfig.tsbuildinfo && tsc -p tsconfig.typecheck.json --noEmit",
    "perf:collect": "lhci collect --config=.lighthouserc.json",
    "perf:assert": "lhci assert --config=.lighthouserc.json",
    "perf:lighthouse": "lhci autorun --config=.lighthouserc.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:local:up": "docker compose -p picc-web-app up -d postgres",
    "db:local:wait": "docker exec picc-postgres sh -lc 'until pg_isready -U postgres -d picc_crm; do sleep 1; done'",
    "db:local:init": "docker exec picc-postgres sh -lc \"psql -U postgres -d postgres -tc \\\"SELECT 1 FROM pg_database WHERE datname = 'picc_crm_local'\\\" | grep -q 1 || createdb -U postgres picc_crm_local\" && docker exec picc-postgres psql -U postgres -d picc_crm_local -c \"CREATE EXTENSION IF NOT EXISTS postgis;\"",
    "db:local:push": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/picc_crm_local?schema=public prisma db push",
    "db:local:seed": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/picc_crm_local?schema=public tsx prisma/seed.ts",
    "db:local:setup": "npm run db:local:up && npm run db:local:wait && npm run db:local:init && npm run db:local:push && npm run db:local:seed",
    "db:local:reset": "docker exec picc-postgres dropdb -U postgres --if-exists picc_crm_local && npm run db:local:init && npm run db:local:push && npm run db:local:seed",
    "db:local:studio": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/picc_crm_local?schema=public prisma studio",
    "native:typecheck": "npm --prefix apps/native run typecheck",
    "sync:directus": "tsx services/directus-sync/src/index.ts",
    "sync:odoo": "tsx services/odoo-sync/src/index.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.39.5",
    "@hookform/resolvers": "^4.1.0",
    "@prisma/client": "^6.3.0",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-hover-card": "^1.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-query": "^5.66.8",
    "@tanstack/react-table": "^8.21.2",
    "@tanstack/react-virtual": "^3.12.1",
    "@vis.gl/react-google-maps": "^1.5.4",
    "@xyflow/react": "^12.5.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.4.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.475.0",
    "next": "^15.5.18",
    "next-themes": "^0.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "sharp": "^0.34.5",
    "sonner": "^1.7.2",
    "tailwind-merge": "^2.6.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^15.5.18",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.19.0",
    "eslint-config-next": "^15.5.18",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "^8.5.1",
    "prisma": "^6.3.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
