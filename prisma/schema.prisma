  org             OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  integrationId   String
  integration     IntegrationConnection @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  module          String
  status          IntegrationSyncStatus @default(RUNNING)
  startedAt       DateTime              @default(now())
  finishedAt      DateTime?
  recordsIn       Int                   @default(0)
  recordsUpserted Int                   @default(0)
  recordsErrored  Int                   @default(0)
  error           String?
  metadata        Json?

  @@index([integrationId, startedAt])
}

model ImportJob {
  id            String                @id @default(cuid())
  orgId         String
  org           OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  entity        String
  filename      String
  status        WorkflowStatus        @default(SUBMITTED)
  rowsProcessed Int                   @default(0)
  rowsErrored   Int                   @default(0)
  createdBy     String
  createdAt     DateTime              @default(now())
}

model ExportJob {
  id          String                @id @default(cuid())
  orgId       String
  org         OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  entity      String
  status      WorkflowStatus        @default(SUBMITTED)
  recordCount Int                   @default(0)
  createdBy   String
  createdAt   DateTime              @default(now())
}

model SpatialGeocodeCache {
  id                String   @id @default(cuid())
  addressNormalized String   @unique
  lat               Float
  lng               Float
  formattedAddress  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model NotionCacheSnapshot {
  key                     String    @id
  payload                 Json
  recordsRead             Int       @default(0)
  unresolvedLocationCount Int       @default(0)
  lastEditedMax           DateTime?
  syncedAt                DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
}

model Territory {
  id                 String                @id @default(cuid())
  orgId              String
  org                OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  color              String                @default("#ef4444")
  borderWidth        Int                   @default(2)
  isVisibleByDefault Boolean               @default(true)
  geojson            Json?
  createdByEmail     String?
  updatedByEmail     String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([orgId, name])
}

model TerritoryMarker {
  id                 String                @id @default(cuid())
  orgId              String
  org                OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  address            String?
  lat                Float
  lng                Float
  color              String                @default("#0f172a")
  kind               String                @default("home")
  isVisibleByDefault Boolean               @default(true)
  createdByEmail     String?
  updatedByEmail     String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([orgId, kind, name])
}

model SalesRoute {
  id                   String                                    @id @default(cuid())
  orgId                String
  org                  OrganizationWorkspace                     @relation(fields: [orgId], references: [id], onDelete: Cascade)
