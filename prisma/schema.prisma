generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPS_TEAM
  SALES_REP
  FINANCE
  BRAND_AMBASSADOR
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum ActivityType {
  MESSAGE_SENT
  MESSAGE_RECEIVED
  TASK_CREATED
  TASK_COMPLETED
  NOTE_ADDED
  STAGE_CHANGED
  APPOINTMENT_CREATED
  APPOINTMENT_UPDATED
  OPPORTUNITY_CREATED
  OPPORTUNITY_UPDATED
  CONTACT_UPDATED
  ACCOUNT_UPDATED
  IMPORT
  EXPORT
  QUICK_LOG
}

enum Channel {
  EMAIL
  SMS
  PHONE_CALL
  WHATSAPP
  OTHER
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
}

enum WorkflowStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  COMPLETED
}

enum IntegrationProvider {
  NOTION
  GOOGLE_SHEETS
  GMAIL
  GHL
}

enum IntegrationSyncStatus {
  IDLE
  RUNNING
  SUCCESS
  ERROR
}

model OrganizationWorkspace {
  id              String                  @id @default(cuid())
  clerkOrgId      String                  @unique
  name            String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  memberships     Membership[]
  accounts        Account[]
  contacts        Contact[]
  tags            Tag[]
  pipelines       Pipeline[]
  opportunities   Opportunity[]
  tasks           Task[]
  appointments    Appointment[]
  conversations   Conversation[]
  messages        Message[]
  activityLogs    ActivityLog[]
  savedViews      SavedView[]
  notifications   Notification[]
  templates       Template[]
  customFields    CustomFieldDefinition[]
  customFieldOptions CustomFieldOption[]
  accountCustomFieldValues AccountCustomFieldValue[]
  contactCustomFieldValues ContactCustomFieldValue[]
  editSuggestions EditSuggestion[]
  stages          Stage[]
  referrals       ReferralRecord[]
  pennyBundles    PennyBundleCreditSubmission[]
  overdueSnaps    OverdueSnapshot[]
  vendorDayEvents VendorDayEvent[]
  sampleRequests  SampleBoxRequest[]
  nabisOrders     NabisOrder[]
  nabisLines      NabisOrderLine[]
  integrations    IntegrationConnection[]
  externalMaps    ExternalRecordMap[]
  checkpoints     SyncCheckpoint[]
  syncRuns        SyncRun[]
  importJobs      ImportJob[]
  exportJobs      ExportJob[]
}

model Membership {
  id            String                @id @default(cuid())
  orgId         String
  org           OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  clerkUserId   String
  role          Role
  source        String                @default("NOTION_SYNC")
  active        Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([orgId, clerkUserId])
  @@index([orgId, role])
}

model Account {
  id                    String                           @id @default(cuid())
  orgId                 String
  org                   OrganizationWorkspace            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name                  String
  licenseNumber         String
  address1              String
  address2              String?
  city                  String
  state                 String
  zipcode               String
  phone                 String?
  status                RecordStatus                     @default(ACTIVE)
  lastContactedAt       DateTime?
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt
  contacts              Contact[]
  accountTags           AccountTag[]
  accountFieldValues    AccountCustomFieldValue[]
  opportunities         Opportunity[]
  tasks                 Task[]
  appointments          Appointment[]
  conversations         Conversation[]
  messages              Message[]
  activityLogs          ActivityLog[]
  referrals             ReferralRecord[]
  pennyBundles          PennyBundleCreditSubmission[]
  overdueSnapshots      OverdueSnapshot[]
  vendorDayEvents       VendorDayEvent[]
  sampleBoxRequests     SampleBoxRequest[]
  nabisOrders           NabisOrder[]
  editSuggestions       EditSuggestion[]

  @@unique([orgId, licenseNumber])
  @@index([orgId, name])
  @@index([orgId, status])
}

model Contact {
  id                  String                    @id @default(cuid())
  orgId               String
  org                 OrganizationWorkspace     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId           String
  account             Account                   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  firstName           String
  lastName            String
  roleTitle           String
  email               String?
  phone               String?
  status              RecordStatus              @default(ACTIVE)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  contactTags         ContactTag[]
  contactFieldValues  ContactCustomFieldValue[]
  opportunities       Opportunity[]
  tasks               Task[]
  appointments        Appointment[]
  conversations       Conversation[]
  messages            Message[]
  activityLogs        ActivityLog[]
  editSuggestions     EditSuggestion[]
  sampleBoxRequests   SampleBoxRequest[]

  @@index([orgId, accountId])
  @@index([orgId, status])
  @@index([orgId, email])
}

model Tag {
  id          String                @id @default(cuid())
  orgId       String
  org         OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  color       String                @default("#3b82f6")
  createdAt   DateTime              @default(now())
  accountTags AccountTag[]
  contactTags ContactTag[]

  @@unique([orgId, name])
}

model AccountTag {
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([accountId, tagId])
}

model ContactTag {
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model CustomFieldDefinition {
  id          String                @id @default(cuid())
  orgId       String
  org         OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  entityType  String
  key         String
  label       String
  dataType    String
  required    Boolean               @default(false)
  createdAt   DateTime              @default(now())
  options     CustomFieldOption[]
  accountVals AccountCustomFieldValue[]
  contactVals ContactCustomFieldValue[]

  @@unique([orgId, entityType, key])
}

model CustomFieldOption {
  id              String                @id @default(cuid())
  orgId           String
  org             OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  definitionId    String
  definition      CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  value           String
  label           String
  sortOrder       Int                   @default(0)

  @@index([definitionId, sortOrder])
}

model AccountCustomFieldValue {
  id            String                @id @default(cuid())
  orgId         String
  org           OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId     String
  account       Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  definitionId  String
  definition    CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  value         Json
  updatedAt     DateTime              @updatedAt

  @@unique([accountId, definitionId])
}

model ContactCustomFieldValue {
  id            String                @id @default(cuid())
  orgId         String
  org           OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contactId     String
  contact       Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  definitionId  String
  definition    CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  value         Json
  updatedAt     DateTime              @updatedAt

  @@unique([contactId, definitionId])
}

model Pipeline {
  id             String                @id @default(cuid())
  orgId          String
  org            OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  stages         Stage[]
  opportunities  Opportunity[]

  @@unique([orgId, name])
}

model Stage {
  id             String                @id @default(cuid())
  orgId          String
  org            OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipelineId     String
  pipeline       Pipeline              @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name           String
  color          String                @default("#3b82f6")
  probability    Int                   @default(10)
  sortOrder      Int                   @default(0)
  opportunities  Opportunity[]

  @@unique([pipelineId, name])
  @@index([pipelineId, sortOrder])
}

model Opportunity {
  id                String                @id @default(cuid())
  orgId             String
  org               OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipelineId        String
  pipeline          Pipeline              @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stageId           String
  stage             Stage                 @relation(fields: [stageId], references: [id], onDelete: Restrict)
  accountId         String
  account           Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  ownerClerkUserId  String
  name              String
  value             Decimal               @default(0)
  status            OpportunityStatus     @default(OPEN)
  probability       Int                   @default(10)
  expectedCloseDate DateTime?
  notes             String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  tasks             Task[]
  appointments      Appointment[]
  activityLogs      ActivityLog[]
  referrals         ReferralRecord[]

  @@index([orgId, accountId])
  @@index([orgId, stageId])
  @@index([orgId, status])
}

model Task {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId        String?
  contact          Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId    String?
  opportunity      Opportunity?          @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  assignedToUserId String
  title            String
  description      String?
  dueDate          DateTime?
  status           TaskStatus            @default(OPEN)
  priority         TaskPriority          @default(MEDIUM)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  activityLogs     ActivityLog[]

  @@index([orgId, accountId])
  @@index([orgId, assignedToUserId])
  @@index([orgId, status])
}

model Appointment {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId        String?
  contact          Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId    String?
  opportunity      Opportunity?          @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  title            String
  description      String?
  startsAt         DateTime
  endsAt           DateTime
  reminderMinutes  Int?
  createdByUserId  String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  activityLogs     ActivityLog[]

  @@index([orgId, accountId])
  @@index([orgId, startsAt])
}

model Conversation {
  id                String                @id @default(cuid())
  orgId             String
  org               OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId         String
  account           Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  channel           Channel
  subject           String?
  assignedToUserId  String?
  unreadCount       Int                   @default(0)
  lastMessageAt     DateTime?
  isMock            Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  messages          Message[]

  @@index([orgId, accountId])
  @@index([orgId, channel])
}

model Message {
  id                String                @id @default(cuid())
  orgId             String
  org               OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversationId    String
  conversation      Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  accountId         String
  account           Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  channel           Channel
  direction         String
  subject           String?
  body              String
  providerMessageId String?
  isMock            Boolean               @default(false)
  sentAt            DateTime              @default(now())
  createdByUserId   String?
  activityLogs      ActivityLog[]

  @@index([orgId, accountId])
  @@index([orgId, conversationId])
  @@index([orgId, sentAt])
}

model ActivityLog {
  id               String           @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId        String?
  contact          Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId    String?
  opportunity      Opportunity?     @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  taskId           String?
  task             Task?            @relation(fields: [taskId], references: [id], onDelete: SetNull)
  appointmentId    String?
  appointment      Appointment?     @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  messageId        String?
  message          Message?         @relation(fields: [messageId], references: [id], onDelete: SetNull)
  actorClerkUserId String
  type             ActivityType
  title            String
  description      String?
  channel          Channel?
  metadata         Json?
  createdAt        DateTime         @default(now())

  @@index([orgId, accountId, createdAt])
  @@index([orgId, type, createdAt])
}

model SavedView {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownerClerkUserId String
  entity           String
  name             String
  config           Json
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([orgId, ownerClerkUserId, entity])
}

model Notification {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userClerkId      String
  title            String
  body             String?
  readAt           DateTime?
  metadata         Json?
  createdAt        DateTime              @default(now())

  @@index([orgId, userClerkId, createdAt])
}

model Template {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  channel          Channel
  name             String
  content          String
  createdByUserId  String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([orgId, channel])
}

model EditSuggestion {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId        String?
  contact          Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  suggestedBy      String
  approvedBy       String?
  status           WorkflowStatus        @default(SUBMITTED)
  patch            Json
  reason           String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([orgId, status, createdAt])
}

model ReferralRecord {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  opportunityId    String?
  opportunity      Opportunity?          @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  source           String
  referredBy       String
  orderNumber      String?
  orderTotal       Decimal?              @db.Decimal(12, 2)
  status           WorkflowStatus        @default(SUBMITTED)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([orgId, status, createdAt])
}

model PennyBundleCreditSubmission {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  vendorDayEventId String?
  vendorDayEvent   VendorDayEvent?       @relation(fields: [vendorDayEventId], references: [id], onDelete: SetNull)
  orderNumber      String?
  creditMemo       String?
  creditAmount     Decimal?              @db.Decimal(12, 2)
  status           WorkflowStatus        @default(SUBMITTED)
  requestedBy      String
  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([orgId, status, createdAt])
}

model OverdueSnapshot {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sourceLicenseId  String?
  creditStatus     String?
  overdueOrders    Int                   @default(0)
  daysOverdue1     Int                   @default(0)
  daysOverdue2     Int                   @default(0)
  daysOverdue3     Int                   @default(0)
  amountOverdue    Decimal?              @db.Decimal(12, 2)
  snapshotDate     DateTime              @default(now())

  @@index([orgId, snapshotDate])
  @@index([orgId, accountId])
}

model VendorDayEvent {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  eventDate        DateTime
  status           WorkflowStatus        @default(SUBMITTED)
  repName          String?
  ambassadorName   String?
  vdContact        String?
  vdContactEmail   String?
  vdContactPhone   String?
  promoStatus      String?
  notes            String?
  createdBy        String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  pennyBundles     PennyBundleCreditSubmission[]

  @@index([orgId, eventDate])
  @@index([orgId, status])
}

model SampleBoxRequest {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId        String?
  contact          Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  requestedBy      String
  status           WorkflowStatus        @default(SUBMITTED)
  requestReason    String
  approvedBy       String?
  fulfilledAt      DateTime?
  shippingNotes    String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([orgId, status, createdAt])
}

model NabisOrder {
  id                String                @id @default(cuid())
  orgId             String
  org               OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId         String?
  account           Account?              @relation(fields: [accountId], references: [id], onDelete: SetNull)
  externalOrderId   String
  orderNumber       String?
  licensedLocationId String?
  licensedLocationName String?
  orderTotal        Decimal?              @db.Decimal(12, 2)
  paymentStatus     String?
  deliveryDate      DateTime?
  salesRep          String?
  poSoNumber        String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  lines             NabisOrderLine[]

  @@unique([orgId, externalOrderId])
  @@index([orgId, orderNumber])
}

model NabisOrderLine {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  nabisOrderId     String
  nabisOrder       NabisOrder            @relation(fields: [nabisOrderId], references: [id], onDelete: Cascade)
  externalOrderId  String
  productName      String
  quantity         Decimal?              @db.Decimal(10, 2)
  unitPrice        Decimal?              @db.Decimal(12, 4)
  isSample         Boolean               @default(false)
  itemStrain       String?
  itemCategory     String?
  itemClass        String?
  createdAt        DateTime              @default(now())

  @@index([orgId, externalOrderId])
}

model IntegrationConnection {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  provider         IntegrationProvider
  name             String
  status           IntegrationSyncStatus @default(IDLE)
  config           Json
  enabled          Boolean               @default(true)
  lastSyncedAt     DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  checkpoints      SyncCheckpoint[]
  syncRuns         SyncRun[]
  externalMaps     ExternalRecordMap[]

  @@index([orgId, provider])
}

model ExternalRecordMap {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  integrationId    String
  integration      IntegrationConnection @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  provider         IntegrationProvider
  externalId       String
  localModel       String
  localId          String
  createdAt        DateTime              @default(now())

  @@unique([orgId, provider, externalId, localModel])
  @@index([orgId, localModel, localId])
}

model SyncCheckpoint {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  integrationId    String
  integration      IntegrationConnection @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  module           String
  cursor           String?
  checksum         String?
  status           IntegrationSyncStatus @default(IDLE)
  metadata         Json?
  updatedAt        DateTime              @updatedAt

  @@unique([integrationId, module])
}

model SyncRun {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  integrationId    String
  integration      IntegrationConnection @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  module           String
  status           IntegrationSyncStatus @default(RUNNING)
  startedAt        DateTime              @default(now())
  finishedAt       DateTime?
  recordsIn        Int                   @default(0)
  recordsUpserted  Int                   @default(0)
  recordsErrored   Int                   @default(0)
  error            String?
  metadata         Json?

  @@index([integrationId, startedAt])
}

model ImportJob {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  entity           String
  filename         String
  status           WorkflowStatus        @default(SUBMITTED)
  rowsProcessed    Int                   @default(0)
  rowsErrored      Int                   @default(0)
  createdBy        String
  createdAt        DateTime              @default(now())
}

model ExportJob {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  entity           String
  status           WorkflowStatus        @default(SUBMITTED)
  recordCount      Int                   @default(0)
  createdBy        String
  createdAt        DateTime              @default(now())
}

model SpatialGeocodeCache {
  id                String   @id @default(cuid())
  addressNormalized String   @unique
  lat               Float
  lng               Float
  formattedAddress  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model NotionCacheSnapshot {
  key                     String   @id
  payload                 Json
  recordsRead             Int      @default(0)
  unresolvedLocationCount Int      @default(0)
  lastEditedMax           DateTime?
  syncedAt                DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
