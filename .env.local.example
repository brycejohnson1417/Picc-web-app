NODE_ENV=development
DEMO_MODE=true

# Core local app
NEXT_PUBLIC_APP_URL=http://localhost:3010
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/picc_crm_local?schema=public

# Clerk is optional in local demo mode. Leave blank to bypass auth locally.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/territory
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/territory

# Optional local integration keys. Leave blank unless you are testing that integration.
NOTION_API_KEY=
NOTION_MASTER_LIST_DATABASE_ID=
NOTION_MEETING_NOTES_DATA_SOURCE_ID=
NOTION_MEETING_NOTES_DATABASE_ID=
NOTION_VENDOR_DAY_DATA_SOURCE_ID=
NOTION_VENDOR_DAY_DATABASE_ID=
NOTION_VENDOR_DAY_EVENTS_DATABASE_ID=
NOTION_CONTACTS_DATABASE_ID=
NOTION_SYNC_TTL_MINUTES=20

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
GOOGLE_MAPS_SERVER_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_ROUTES_API_KEY=
GOOGLE_ROUTE_OPTIMIZATION_API_KEY=
TERRITORY_STALE_SYNC_GEOCODE_LOOKUPS=12
TERRITORY_FORCE_SYNC_GEOCODE_LOOKUPS=80
TERRITORY_GOOGLE_ROUTES_DAILY_CAP=2500
TERRITORY_GOOGLE_ROUTE_OPTIMIZATION_DAILY_CAP=750
TERRITORY_GOOGLE_MONTHLY_BUDGET_USD=100
TERRITORY_GOOGLE_GEOCODING_USD_PER_1000=5
TERRITORY_GOOGLE_ROUTES_COMPUTE_USD_PER_1000=5
TERRITORY_GOOGLE_ROUTE_OPTIMIZE_USD_PER_1000=10

CRON_SECRET=local_dev_only
TERRITORY_ORG_ID=org_picc_demo
TERRITORY_ALLOWED_EMAILS=
TERRITORY_ADMIN_EMAILS=
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
NABIS_MASTER_SHEET_PATH=
NABIS_API_KEY=
NABIS_API_BASE_URL=https://platform-api.nabis.pro
PUBLIC_NABIS_CACHE_TTL_SECONDS=180

# Set to 1 when you need verbose Prisma query logs.
PRISMA_QUERY_LOG=0

# Optional provider adapters and service containers.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=
EXPO_PUBLIC_API_BASE_URL=http://localhost:3010
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=
ODOO_URL=http://localhost:8069
ODOO_DB=picc_crm
ODOO_USERNAME=admin
ODOO_PASSWORD=
