generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  OPS_TEAM
  SALES_REP
  FINANCE
  BRAND_AMBASSADOR
  GUEST_VIEWER
}

enum GuestInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum ActivityType {
  MESSAGE_SENT
  MESSAGE_RECEIVED
  TASK_CREATED
  TASK_COMPLETED
  NOTE_ADDED
  STAGE_CHANGED
  APPOINTMENT_CREATED
  APPOINTMENT_UPDATED
  OPPORTUNITY_CREATED
  OPPORTUNITY_UPDATED
  CONTACT_UPDATED
  ACCOUNT_UPDATED
  IMPORT
  EXPORT
  QUICK_LOG
}

enum Channel {
  EMAIL
  SMS
  PHONE_CALL
  WHATSAPP
  OTHER
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
}

enum WorkflowStatus {
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
  COMPLETED
}

enum IntegrationProvider {
  NOTION
  GOOGLE_SHEETS
  GMAIL
  GHL
  NABIS
}

enum IntegrationSyncStatus {
  IDLE
  RUNNING
  SUCCESS
  ERROR
}

enum AccountIdentityType {
  ACCOUNT_ID
  NOTION_PAGE_ID
  LICENSED_LOCATION_ID
  NABIS_RETAILER_ID
  LICENSE_NUMBER
  ALIAS
}

// RETIRED CLUSTER, DO NOT EXTEND:
// Vendor Day dispatch/scheduling, Worker/Brand Ambassador coordination, Payroll,
// and NotificationPreference are dormant in this cleanup wave. They remain in
// schema only to avoid a destructive production migration. Drop them together
// later in one explicit approval-lane migration after read-only production
// counts/export. Territory vendorDayStatus metadata is separate and still live.
enum VendorDayRequestSource {
  STORE_REQUESTED
  REP_REQUESTED
  BA_REQUESTED
  OPS_REQUESTED
  ADMIN_REQUESTED
  AUTO_GENERATED
}

enum VendorDayRequestStatus {
  PROPOSED
  REQUESTED
  AWAITING_REP_APPROVAL
  READY_FOR_DISPATCH
  OFFER_PENDING
  ASSIGNED
  PASSED_OFF
  NO_SHOW
  EXCEPTION
  DISPUTED
  COMPLETED
  CANCELLED
}

enum VendorDayOfferStatus {
  OPEN
  ACCEPTED
  DECLINED
  WITHDRAWN
  EXPIRED
}

enum VendorDayAssignmentStatus {
  ASSIGNED
  PASSED_OFF
  NO_SHOW
  CHECKED_IN
  CHECKED_OUT
  COMPLETED
  EXCEPTION
  DISPUTED
  CANCELLED
}

enum VendorDayArtifactType {
  CHECK_IN_PHOTO
  CHECK_OUT_PHOTO
  POS_REPORT
  SCREENSHOT
  EXTRA
}

enum WorkerSkillTier {
  TRAINEE
  STANDARD
  ALL_STAR
}

enum CalendarConnectionProvider {
  GOOGLE
  APPLE
}

enum CalendarConnectionStatus {
  ACTIVE
  STALE
  ERROR
  REVOKED
  MANUAL_ONLY
}

enum PayrollBatchStatus {
  OPEN
  CLOSED
  EXPORTED
  PAID
}

enum PayrollLineStatus {
  PENDING
  DISPUTED
  APPROVED
  PAID
  VOID
}

enum NotificationCategory {
  OFFERS
  ASSIGNMENTS
  APPROVALS
  PAYROLL
  SYSTEM_ALERTS
  EVENT_RECAPS
  EXCEPTIONS
}

model OrganizationWorkspace {
  id                        String                        @id @default(cuid())
  clerkOrgId                String                        @unique
  name                      String
  createdAt                 DateTime                      @default(now())
  updatedAt                 DateTime                      @updatedAt
  memberships               Membership[]
  accounts                  Account[]
  contacts                  Contact[]
  tags                      Tag[]
  pipelines                 Pipeline[]
  opportunities             Opportunity[]
  tasks                     Task[]
  appointments              Appointment[]
  conversations             Conversation[]
  messages                  Message[]
  activityLogs              ActivityLog[]
  savedViews                SavedView[]
  notifications             Notification[]
  templates                 Template[]
  customFields              CustomFieldDefinition[]
  customFieldOptions        CustomFieldOption[]
  accountCustomFieldValues  AccountCustomFieldValue[]
  contactCustomFieldValues  ContactCustomFieldValue[]
  editSuggestions           EditSuggestion[]
  stages                    Stage[]
  referrals                 ReferralRecord[]
  pennyBundles              PennyBundleCreditSubmission[]
  overdueSnaps              OverdueSnapshot[]
  vendorDayEvents           VendorDayEvent[]
  sampleRequests            SampleBoxRequest[]
  nabisOrders               NabisOrder[]
  nabisLines                NabisOrderLine[]
  nabisRetailers            NabisRetailer[]
  nabisMetrics              NabisStoreMetricDaily[]
  identityMappings          AccountIdentityMapping[]
  workerProfiles            WorkerProfile[]
  employers                 Employer[]
  workerAvailabilityRules   WorkerAvailabilityRule[]
  workerAvailabilityBlocks  WorkerAvailabilityBlock[]
  workerCalendarConnections WorkerCalendarConnection[]
  workerGearItems           WorkerGearItem[]
  workerCertifications      WorkerCertification[]
  workerBrandTrainings      WorkerBrandTraining[]
  workerSkillTags           WorkerSkillTag[]
  workerReviews             WorkerReview[]
  roleGrants                MembershipRoleGrant[]
  operationalInvites        OperationalAccessInvite[]
  vendorDayRequests         VendorDayRequest[]
  vendorDayOffers           VendorDayOffer[]
  vendorDayAssignments      VendorDayAssignment[]
  vendorDayExecutions       VendorDayExecution[]
  vendorDayArtifacts        VendorDayArtifact[]
  payrollBatches            PayrollBatch[]
  payrollLineItems          PayrollLineItem[]
  vendorDayRoiSnapshots     VendorDayRoiSnapshot[]
  notificationPreferences   NotificationPreference[]
  integrations              IntegrationConnection[]
  externalMaps              ExternalRecordMap[]
  checkpoints               SyncCheckpoint[]
  syncRuns                  SyncRun[]
  importJobs                ImportJob[]
  exportJobs                ExportJob[]
  salesRoutes               SalesRoute[]
  territories               Territory[]
  territoryMarkers          TerritoryMarker[]
  checkIns                  CheckIn[]
  territoryCheckInMirrors   TerritoryCheckInMirror[]
  territorySyncJobs         TerritoryStoreSyncJob[]
  territoryStores           TerritoryStoreReadModel[]
  territoryFilterPresets    TerritoryFilterPreset[]
  appSessionAudits          AppSessionAudit[]
  guestAccessInvites        GuestAccessInvite[]
  auditEvents               AuditEvent[]
  policySnapshots           PolicySnapshot[]
}

model Membership {
  id              String                @id @default(cuid())
  orgId           String
  org             OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  clerkUserId     String
  role            Role
  testModeEnabled Boolean               @default(false)
  source          String                @default("NOTION_SYNC")
  active          Boolean               @default(true)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([orgId, clerkUserId])
  @@index([orgId, role])
}

model MembershipRoleGrant {
  id          String                @id @default(cuid())
  orgId       String
  org         OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  clerkUserId String
  role        Role
  active      Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([orgId, clerkUserId, role])
  @@index([orgId, clerkUserId, active])
}

model OperationalAccessInvite {
  id                    String                @id @default(cuid())
  orgId                 String
  org                   OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email                 String
  role                  Role                  @default(BRAND_AMBASSADOR)
  active                Boolean               @default(true)
  invitedByClerkUserId  String
  invitedByEmail        String?
  note                  String?
  acceptedAt            DateTime?
  acceptedByClerkUserId String?
  revokedAt             DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@unique([orgId, email])
  @@index([email, active])
}

model GuestAccessInvite {
  id                    String                @id @default(cuid())
  orgId                 String
  org                   OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email                 String
  status                GuestInviteStatus     @default(PENDING)
  invitedByClerkUserId  String
  invitedByEmail        String?
  note                  String?
  acceptedAt            DateTime?
  acceptedByClerkUserId String?
  revokedAt             DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@unique([orgId, email])
  @@index([orgId, status, createdAt])
  @@index([email, status])
}

model Account {
  id                         String                               @id @default(cuid())
  orgId                      String
  org                        OrganizationWorkspace                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name                       String
  notionPageId               String?
  licensedLocationId         String?
  nabisRetailerId            String?
  licenseNumber              String
  address1                   String
  address2                   String?
  city                       String
  state                      String
  zipcode                    String
  phone                      String?
  geoLat                     Float?
  geoLng                     Float?
  geoPoint                   Unsupported("geometry(Point,4326)")?
  status                     RecordStatus                         @default(ACTIVE)
  vendorDaySuppressed        Boolean                              @default(false)
  vendorDaySuppressionReason String?
  lastContactedAt            DateTime?
  createdAt                  DateTime                             @default(now())
  updatedAt                  DateTime                             @updatedAt
  contacts                   Contact[]
  accountTags                AccountTag[]
  accountFieldValues         AccountCustomFieldValue[]
  opportunities              Opportunity[]
  tasks                      Task[]
  appointments               Appointment[]
  conversations              Conversation[]
  messages                   Message[]
  activityLogs               ActivityLog[]
  referrals                  ReferralRecord[]
  pennyBundles               PennyBundleCreditSubmission[]
  overdueSnapshots           OverdueSnapshot[]
  vendorDayEvents            VendorDayEvent[]
  vendorDayRequests          VendorDayRequest[]
  workerReviews              WorkerReview[]
  roiSnapshots               VendorDayRoiSnapshot[]
  sampleBoxRequests          SampleBoxRequest[]
  nabisOrders                NabisOrder[]
  nabisRetailers             NabisRetailer[]
  dailyNabisMetrics          NabisStoreMetricDaily[]
  identityMappings           AccountIdentityMapping[]
  editSuggestions            EditSuggestion[]

  @@unique([orgId, licenseNumber])
  @@unique([orgId, notionPageId])
  @@unique([orgId, licensedLocationId])
  @@unique([orgId, nabisRetailerId])
  @@index([orgId, name])
  @@index([orgId, status])
  @@index([orgId, notionPageId])
  @@index([orgId, licensedLocationId])
  @@index([orgId, nabisRetailerId])
}

model Employer {
  id                   String                 @id @default(cuid())
  orgId                String
  org                  OrganizationWorkspace  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name                 String
  isServiceCompany     Boolean                @default(false)
  flatEventRateDollars Decimal?               @db.Decimal(10, 2)
  mileageRateDollars   Decimal?               @db.Decimal(10, 2)
  notes                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  workers              WorkerProfile[]
  payrollLineItems     PayrollLineItem[]
  roiSnapshots         VendorDayRoiSnapshot[]

  @@unique([orgId, name])
  @@index([orgId, isServiceCompany])
}

model Contact {
  id                 String                               @id @default(cuid())
  orgId              String
  org                OrganizationWorkspace                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId          String
  account            Account                              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  firstName          String
  lastName           String
  roleTitle          String
  email              String?
  phone              String?
  geoLat             Float?
  geoLng             Float?
  geoPoint           Unsupported("geometry(Point,4326)")?
  status             RecordStatus                         @default(ACTIVE)
  createdAt          DateTime                             @default(now())
  updatedAt          DateTime                             @updatedAt
  contactTags        ContactTag[]
  contactFieldValues ContactCustomFieldValue[]
  opportunities      Opportunity[]
  tasks              Task[]
  appointments       Appointment[]
  conversations      Conversation[]
  messages           Message[]
  activityLogs       ActivityLog[]
  editSuggestions    EditSuggestion[]
  sampleBoxRequests  SampleBoxRequest[]

  @@index([orgId, accountId])
  @@index([orgId, status])
  @@index([orgId, email])
}

model Tag {
  id          String                @id @default(cuid())
  orgId       String
  org         OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  color       String                @default("#3b82f6")
  createdAt   DateTime              @default(now())
  accountTags AccountTag[]
  contactTags ContactTag[]

  @@unique([orgId, name])
}

model AccountTag {
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([accountId, tagId])
}

model ContactTag {
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model CustomFieldDefinition {
  id          String                    @id @default(cuid())
  orgId       String
  org         OrganizationWorkspace     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  entityType  String
  key         String
  label       String
  dataType    String
  required    Boolean                   @default(false)
  createdAt   DateTime                  @default(now())
  options     CustomFieldOption[]
  accountVals AccountCustomFieldValue[]
  contactVals ContactCustomFieldValue[]

  @@unique([orgId, entityType, key])
}

model CustomFieldOption {
  id           String                @id @default(cuid())
  orgId        String
  org          OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  definitionId String
  definition   CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  value        String
  label        String
  sortOrder    Int                   @default(0)

  @@index([definitionId, sortOrder])
}

model AccountCustomFieldValue {
  id           String                @id @default(cuid())
  orgId        String
  org          OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId    String
  account      Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  definitionId String
  definition   CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  value        Json
  updatedAt    DateTime              @updatedAt

  @@unique([accountId, definitionId])
}

model ContactCustomFieldValue {
  id           String                @id @default(cuid())
  orgId        String
  org          OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contactId    String
  contact      Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  definitionId String
  definition   CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  value        Json
  updatedAt    DateTime              @updatedAt

  @@unique([contactId, definitionId])
}

model Pipeline {
  id            String                @id @default(cuid())
  orgId         String
  org           OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  stages        Stage[]
  opportunities Opportunity[]

  @@unique([orgId, name])
}

model Stage {
  id            String                @id @default(cuid())
  orgId         String
  org           OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipelineId    String
  pipeline      Pipeline              @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  name          String
  color         String                @default("#3b82f6")
  probability   Int                   @default(10)
  sortOrder     Int                   @default(0)
  opportunities Opportunity[]

  @@unique([pipelineId, name])
  @@index([pipelineId, sortOrder])
}

model Opportunity {
  id                String                @id @default(cuid())
  orgId             String
  org               OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  pipelineId        String
  pipeline          Pipeline              @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stageId           String
  stage             Stage                 @relation(fields: [stageId], references: [id], onDelete: Restrict)
  accountId         String
  account           Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  ownerClerkUserId  String
  name              String
  value             Decimal               @default(0)
  status            OpportunityStatus     @default(OPEN)
  probability       Int                   @default(10)
  expectedCloseDate DateTime?
  notes             String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  tasks             Task[]
  appointments      Appointment[]
  activityLogs      ActivityLog[]
  referrals         ReferralRecord[]

  @@index([orgId, accountId])
  @@index([orgId, stageId])
  @@index([orgId, status])
}

model Task {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId        String?
  contact          Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId    String?
  opportunity      Opportunity?          @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  assignedToUserId String
  title            String
  description      String?
  dueDate          DateTime?
  status           TaskStatus            @default(OPEN)
  priority         TaskPriority          @default(MEDIUM)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  activityLogs     ActivityLog[]

  @@index([orgId, accountId])
  @@index([orgId, assignedToUserId])
  @@index([orgId, status])
}

model Appointment {
  id              String                @id @default(cuid())
  orgId           String
  org             OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId       String
  account         Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId   String?
  opportunity     Opportunity?          @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  title           String
  description     String?
  startsAt        DateTime
  endsAt          DateTime
  reminderMinutes Int?
  createdByUserId String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  activityLogs    ActivityLog[]

  @@index([orgId, accountId])
  @@index([orgId, startsAt])
}

model Conversation {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId        String?
  contact          Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  channel          Channel
  subject          String?
  assignedToUserId String?
  unreadCount      Int                   @default(0)
  lastMessageAt    DateTime?
  isMock           Boolean               @default(false)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  messages         Message[]

  @@index([orgId, accountId])
  @@index([orgId, channel])
}

model Message {
  id                String                @id @default(cuid())
  orgId             String
  org               OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversationId    String
  conversation      Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  accountId         String
  account           Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId         String?
  contact           Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  channel           Channel
  direction         String
  subject           String?
  body              String
  providerMessageId String?
  isMock            Boolean               @default(false)
  sentAt            DateTime              @default(now())
  createdByUserId   String?
  activityLogs      ActivityLog[]

  @@index([orgId, accountId])
  @@index([orgId, conversationId])
  @@index([orgId, sentAt])
}

model ActivityLog {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId        String?
  contact          Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  opportunityId    String?
  opportunity      Opportunity?          @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  taskId           String?
  task             Task?                 @relation(fields: [taskId], references: [id], onDelete: SetNull)
  appointmentId    String?
  appointment      Appointment?          @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  messageId        String?
  message          Message?              @relation(fields: [messageId], references: [id], onDelete: SetNull)
  actorClerkUserId String
  type             ActivityType
  title            String
  description      String?
  channel          Channel?
  metadata         Json?
  createdAt        DateTime              @default(now())

  @@index([orgId, accountId, createdAt])
  @@index([orgId, type, createdAt])
}

model SavedView {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  ownerClerkUserId String
  entity           String
  name             String
  config           Json
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([orgId, ownerClerkUserId, entity])
}

model Notification {
  id          String                @id @default(cuid())
  orgId       String
  org         OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userClerkId String
  title       String
  body        String?
  readAt      DateTime?
  metadata    Json?
  createdAt   DateTime              @default(now())

  @@index([orgId, userClerkId, createdAt])
}

model Template {
  id              String                @id @default(cuid())
  orgId           String
  org             OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  channel         Channel
  name            String
  content         String
  createdByUserId String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([orgId, channel])
}

model EditSuggestion {
  id          String                @id @default(cuid())
  orgId       String
  org         OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId   String
  account     Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contactId   String?
  contact     Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  suggestedBy String
  approvedBy  String?
  status      WorkflowStatus        @default(SUBMITTED)
  patch       Json
  reason      String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([orgId, status, createdAt])
}

model ReferralRecord {
  id            String                @id @default(cuid())
  orgId         String
  org           OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId     String
  account       Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  opportunityId String?
  opportunity   Opportunity?          @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  source        String
  referredBy    String
  orderNumber   String?
  orderTotal    Decimal?              @db.Decimal(12, 2)
  status        WorkflowStatus        @default(SUBMITTED)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([orgId, status, createdAt])
}

model PennyBundleCreditSubmission {
  id               String                @id @default(cuid())
  orgId            String
  org              OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId        String
  account          Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  vendorDayEventId String?
  vendorDayEvent   VendorDayEvent?       @relation(fields: [vendorDayEventId], references: [id], onDelete: SetNull)
  orderNumber      String?
  creditMemo       String?
  creditAmount     Decimal?              @db.Decimal(12, 2)
  status           WorkflowStatus        @default(SUBMITTED)
  requestedBy      String
  notes            String?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([orgId, status, createdAt])
}

model OverdueSnapshot {
  id              String                @id @default(cuid())
  orgId           String
  org             OrganizationWorkspace @relation(fields: [orgId], references: [id], onDelete: Cascade)
  accountId       String
  account         Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sourceLicenseId String?
  creditStatus    String?
  overdueOrders   Int                   @default(0)
